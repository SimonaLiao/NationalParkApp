<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="NationalPark.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:NationalPark"
    xmlns:controls="using:NationalPark.Controls"
    xmlns:converters="using:NationalPark.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="National Park Tracker">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="MainGrid">
        <Grid.Resources>
            <converters:DateTimeToStringConverter x:Key="DateTimeToStringConverter"/>
            <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <converters:UrlToThumbnailImageConverter x:Key="UrlToThumbnailImageConverter"/>
        </Grid.Resources>
        
        <!-- Homepage with park listing -->
        <ScrollViewer x:Name="HomeView" Visibility="Visible">
            <StackPanel Padding="20" Spacing="24">
                <TextBlock Text="National Park Tracker" 
                          Style="{StaticResource HeaderTextBlockStyle}"
                          HorizontalAlignment="Center"/>
                
                <TextBlock Text="Discover and track your visits to America's beautiful national parks" 
                          Style="{StaticResource SubheaderTextBlockStyle}"
                          HorizontalAlignment="Center"
                          Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>

                <!-- Region Filter Section -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                       CornerRadius="8"
                       Padding="16"
                       HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <FontIcon Glyph="&#xE71C;" 
                                 VerticalAlignment="Center"
                                 Foreground="{ThemeResource SystemAccentColor}"/>
                        <TextBlock Text="Filter by Region:" 
                                  Style="{StaticResource BodyStrongTextBlockStyle}"
                                  VerticalAlignment="Center"/>
                        <ComboBox x:Name="RegionFilterComboBox"
                                 ItemsSource="{x:Bind ViewModel.Regions}"
                                 SelectedItem="{x:Bind ViewModel.SelectedRegion, Mode=TwoWay}"
                                 MinWidth="150"
                                 PlaceholderText="Select Region">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="x:String">
                                    <TextBlock Text="{Binding}" Style="{StaticResource BodyTextBlockStyle}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <TextBox x:Name="SearchTextBox"
                                 Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="Search by name, state, or description..."
                                 MinWidth="280"/>
                        <TextBlock Text="{x:Bind GetParkCountText(ViewModel.Parks.Count), Mode=OneWay}" 
                                  Style="{StaticResource CaptionTextBlockStyle}"
                                  VerticalAlignment="Center"
                                  Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                    </StackPanel>
                </Border>

                <GridView x:Name="ParksGridView"
                         ItemsSource="{x:Bind ViewModel.Parks}"
                         SelectionMode="None"
                         IsItemClickEnabled="True"
                         ItemClick="ParksGridView_ItemClick"
                         Padding="0,20,0,0">
                    <GridView.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                   CornerRadius="12"
                                   Width="350"
                                   Height="280"
                                   Margin="8">
                                <Border.Shadow>
                                    <ThemeShadow />
                                </Border.Shadow>
                                
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="160"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0">
                                        <Image Source="{Binding ImageUrl, Converter={StaticResource UrlToThumbnailImageConverter}}" 
                                              Stretch="UniformToFill"/>
                                        <Border Background="Black" 
                                               Opacity="0.3" 
                                               CornerRadius="12,12,0,0"/>
                                        
                                        <!-- Visit status indicator -->
                                        <Border Background="{ThemeResource SystemAccentColor}"
                                               CornerRadius="12"
                                               Padding="8,4"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Top"
                                               Margin="12"
                                               Visibility="{Binding IsVisited, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <FontIcon Glyph="&#xE73E;" FontSize="12" Foreground="White"/>
                                                <TextBlock Text="Visited" 
                                                          FontSize="12" 
                                                          Foreground="White"
                                                          FontWeight="SemiBold"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Region indicator -->
                                        <Border Background="{ThemeResource SystemControlBackgroundAltHighBrush}"
                                               CornerRadius="8"
                                               Padding="6,3"
                                               HorizontalAlignment="Left"
                                               VerticalAlignment="Top"
                                               Margin="12">
                                            <TextBlock Text="{Binding Region}" 
                                                      FontSize="10" 
                                                      Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}"
                                                      FontWeight="SemiBold"/>
                                        </Border>
                                    </Grid>

                                    <StackPanel Grid.Row="1" 
                                               Padding="16"
                                               Spacing="8">
                                        <TextBlock Text="{Binding Name}" 
                                                  Style="{StaticResource BodyStrongTextBlockStyle}"
                                                  TextWrapping="Wrap"
                                                  MaxLines="2"/>
                                        
                                        <TextBlock Text="{Binding State}" 
                                                  Style="{StaticResource CaptionTextBlockStyle}"
                                                  Foreground="{ThemeResource SystemAccentColor}"/>
                                        
                                        <TextBlock Text="{Binding Description}"
                                                  Style="{StaticResource CaptionTextBlockStyle}"
                                                  Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                                  TextWrapping="Wrap"
                                                  MaxLines="2"
                                                  TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                    <GridView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VariableSizedWrapGrid Orientation="Horizontal" ItemHeight="280" ItemWidth="350"/>
                        </ItemsPanelTemplate>
                    </GridView.ItemsPanel>
                </GridView>
            </StackPanel>
        </ScrollViewer>

        <!-- Park detail view -->
        <controls:ParkDetailControl x:Name="ParkDetailView"
                                   Visibility="Collapsed"
                                   BackRequested="ParkDetailView_BackRequested"
                                   VisitRequested="ParkDetailView_VisitRequested"/>
    </Grid>
</Window>
