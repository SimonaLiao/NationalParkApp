<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="NationalPark.Controls.ParkDetailControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:NationalPark.Controls"
    xmlns:converters="using:NationalPark.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:DateTimeToStringConverter x:Key="DateTimeToStringConverter"/>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <ScrollViewer>
        <StackPanel Padding="20" Spacing="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" 
                          Text="{Binding ParkName}" 
                          Style="{StaticResource TitleTextBlockStyle}"
                          TextWrapping="WrapWholeWords"/>
                
                <Button Grid.Column="1"
                        x:Name="BackButton"
                        Content="← Back to Parks"
                        Click="BackButton_Click"
                        Style="{StaticResource AccentButtonStyle}"/>
            </Grid>

            <TextBlock Text="{Binding State}" 
                      Style="{StaticResource SubtitleTextBlockStyle}"
                      Foreground="{ThemeResource SystemAccentColor}"/>

            <Border CornerRadius="8">
                <Image Source="{Binding ImageUrl}" 
                       Height="300" 
                       Stretch="UniformToFill"/>
            </Border>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Spacing="8">
                    <TextBlock Text="Established" 
                              Style="{StaticResource CaptionTextBlockStyle}"
                              Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                    <TextBlock Text="{Binding EstablishedYear}"
                              Style="{StaticResource BodyTextBlockStyle}"/>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Spacing="8">
                    <TextBlock Text="Area (Acres)" 
                              Style="{StaticResource CaptionTextBlockStyle}"
                              Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                    <TextBlock Text="{Binding AreaInAcres}"
                              Style="{StaticResource BodyTextBlockStyle}"/>
                </StackPanel>
            </Grid>

            <TextBlock Text="Description" 
                      Style="{StaticResource SubheaderTextBlockStyle}"
                      Margin="0,16,0,8"/>
            
            <TextBlock Text="{Binding Description}"
                      Style="{StaticResource BodyTextBlockStyle}"
                      TextWrapping="Wrap"/>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8"
                    Padding="16"
                    Margin="0,16,0,0">
                <StackPanel Spacing="12">
                    <TextBlock Text="Visit Status" 
                              Style="{StaticResource SubheaderTextBlockStyle}"/>
                    
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <FontIcon Glyph="{x:Bind GetVisitStatusIcon(IsVisited), Mode=OneWay}"
                                 Foreground="{x:Bind GetVisitStatusColor(IsVisited), Mode=OneWay}"/>
                        <TextBlock Text="{x:Bind GetVisitStatusText(IsVisited), Mode=OneWay}"
                                  Style="{StaticResource BodyTextBlockStyle}"/>
                    </StackPanel>

                    <Button x:Name="MarkVisitedButton"
                           Content="Mark as Visited"
                           Click="MarkVisitedButton_Click"
                           Style="{StaticResource AccentButtonStyle}"
                           Visibility="{x:Bind GetMarkVisitedVisibility(IsVisited), Mode=OneWay}"/>

                    <Button x:Name="AddAnotherVisitButton"
                           Content="Add Another Visit"
                           Click="MarkVisitedButton_Click"
                           Visibility="{x:Bind GetAddAnotherVisitVisibility(IsVisited), Mode=OneWay}"/>
                </StackPanel>
            </Border>

            <StackPanel Visibility="{x:Bind GetVisitRecordsVisibility(IsVisited), Mode=OneWay}"
                       Margin="0,16,0,0">
                <TextBlock Text="Previous Visits" 
                          Style="{StaticResource SubheaderTextBlockStyle}"
                          Margin="0,0,0,12"/>
                
                <ItemsControl ItemsSource="{Binding VisitRecords}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                   CornerRadius="8"
                                   Padding="12"
                                   Margin="0,0,0,8">
                                <StackPanel Spacing="8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <TextBlock Grid.Column="0"
                                                  Text="{Binding VisitDate, Converter={StaticResource DateTimeToStringConverter}}"
                                                  Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                        
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <TextBlock Text="{Binding Rating}"
                                                      Style="{StaticResource BodyTextBlockStyle}"/>
                                            <TextBlock Text="★"
                                                      Style="{StaticResource BodyTextBlockStyle}"
                                                      Foreground="Gold"
                                                      Margin="4,0,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                    
                                    <TextBlock Text="{Binding Comments}"
                                              Style="{StaticResource BodyTextBlockStyle}"
                                              TextWrapping="Wrap"
                                              Visibility="{Binding Comments, Converter={StaticResource StringToVisibilityConverter}}"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>